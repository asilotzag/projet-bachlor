# === Base de données (PostgreSQL) ===
# Aujourd'hui : URL Neon (cloud gratuit) — https://neon.tech
# Plus tard : URL PostgreSQL locale (même format), seule cette ligne change.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# === Serveur API ===
PORT=4000

# === Auth (Phase 1) ===
JWT_SECRET="changez-moi-en-une-chaine-longue-et-aleatoire"
JWT_EXPIRES_IN="7d"

# === IA (Phase 3) ===
AI_PROVIDER="gemini"           # gemini | ollama
GEMINI_API_KEY=""              # clé gratuite : https://aistudio.google.com/app/apikey
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"
