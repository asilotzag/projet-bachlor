{
  "name": "asmae-pfe",
  "version": "0.1.0",
  "private": true,
  "description": "PFE - Plateforme de gestion d'entreprise (desktop, IA)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,desktop -c blue,green,magenta \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:desktop\"",
    "dev:api": "npm run dev -w @pfe/api",
    "dev:web": "npm run dev -w @pfe/web",
    "dev:desktop": "wait-on tcp:127.0.0.1:5173 && npm run dev -w @pfe/desktop",
    "build": "npm run build -w @pfe/web && npm run build -w @pfe/api && npm run build -w @pfe/desktop",
    "test": "npm run test -w @pfe/api",
    "package:exe": "npm run build -w @pfe/web && npm run package:win -w @pfe/desktop",
    "db:generate": "npm run db:generate -w @pfe/api",
    "db:migrate": "npm run db:migrate -w @pfe/api",
    "db:seed": "npm run db:seed -w @pfe/api",
    "db:studio": "npm run db:studio -w @pfe/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.2"
  }
}
